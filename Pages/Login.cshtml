@page
@model LoginModel
@{
    ViewData["Title"] = "Sign In";
}

<section class="login-panel">
    <h1>Employee Sign In</h1>
    <form method="post" class="stack">
        <div asp-validation-summary="ModelOnly" class="validation"></div>
        <label asp-for="Input.Username"></label>
        <input asp-for="Input.Username" autofocus />
        <span asp-validation-for="Input.Username" class="validation"></span>

        <label asp-for="Input.Password"></label>
        <input asp-for="Input.Password" type="password" />
        <span asp-validation-for="Input.Password" class="validation"></span>

        <button type="submit">Sign in</button>
    </form>
</section>
